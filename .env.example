# --- Host Port Mapping ---
# Override these to avoid conflicts with other services on the host.
CRAWLER_API_PORT=8088
CRAWLER_METRICS_PORT=9098
CRAWLER_REDIS_PORT=6382
CRAWLER_MONGO_PORT=27020
CRAWLER_PROMETHEUS_PORT=9095
CRAWLER_GRAFANA_PORT=3030

# --- API Configuration ---
SERVICE_NAME=crawler-backend
API_PORT=8080
METRICS_PORT=9090
LOG_LEVEL=info

# --- MongoDB ---
MONGO_URI=mongodb://crawler_mongodb:27017
MONGO_DB=crawler
MONGO_POOL_SIZE=100

# --- Redis ---
REDIS_ADDR=crawler_redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Worker Configuration ---
WORKER_CONCURRENCY=200
WORKER_POLL_INTERVAL=100ms
WORKER_BATCH_SIZE=50

# --- Crawler ---
CRAWLER_TIMEOUT=30s
CRAWLER_MAX_RETRIES=3
DEFAULT_USER_AGENT=WK-Crawler/1.0

# --- Webhook ---
WEBHOOK_TIMEOUT=10s
WEBHOOK_MAX_RETRIES=3
