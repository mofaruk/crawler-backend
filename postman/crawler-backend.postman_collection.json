							"name": "OK",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"id\": \"65f1a2b3c1d2e3f4a5b6c7d9\",\n  \"status\": \"running\"\n}"
						}
					]
				},
				{
					"name": "Stop Crawling",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/crawlings/{{crawling_id}}/stop",
							"host": ["{{base_url}}"],
							"path": ["crawlings", "{{crawling_id}}", "stop"]
						},
						"description": "Stop a crawl permanently. This will:\n1. Mark the job as stopped\n2. Delete all pending/processing/retry queues\n3. Clean up deduplication data\n4. Clean up rate limiter data\n\n**This is irreversible.** Already crawled results are preserved in MongoDB."
					},
					"response": [
						{
							"name": "OK",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"id\": \"65f1a2b3c1d2e3f4a5b6c7d9\",\n  \"status\": \"stopped\"\n}"
						}
					]
				},
				{
					"name": "List Crawlings",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/crawlings?skip=0&limit=20",
							"host": ["{{base_url}}"],
