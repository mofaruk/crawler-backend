						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/crawlings/{{crawling_id}}/pause",
							"host": ["{{base_url}}"],
							"path": ["crawlings", "{{crawling_id}}", "pause"]
						},
						"description": "Pause a running crawl. Workers will stop picking up new tasks within milliseconds. In-flight requests will complete.\n\nOnly works when status is `running`."
