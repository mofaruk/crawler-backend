									"key": "header",
									"value": "cf-cache-status",
									"description": "HTTP header name to analyze (must match an extract_data header configured on the site)"
								}
							]
						},
						"description": "Get analytics for a specific HTTP response header across all crawled URLs.\n\nReturns the count of each distinct value for the given header.\n\n**header** (required): The header name to analyze, e.g. `cf-cache-status`, `content-type`, `server`.\n\nThe header must be one that was configured in the site's `extract_data` field."
					},
					"response": [
						{
							"name": "OK",
