							"raw": "{{base_url}}/crawlings/{{crawling_id}}/resume",
							"host": ["{{base_url}}"],
							"path": ["crawlings", "{{crawling_id}}", "resume"]
						},
						"description": "Resume a paused crawl. Workers will immediately start picking up tasks again.\n\nOnly works when status is `paused`."
