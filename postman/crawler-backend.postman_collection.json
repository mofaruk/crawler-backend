				{
					"name": "Get Header Analytics",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/crawlings/{{crawling_id}}/results/analytics?header=cf-cache-status",
							"host": ["{{base_url}}"],
							"path": ["crawlings", "{{crawling_id}}", "results", "analytics"],
